{
  "name": "obsidian-base-board",
  "version": "2.1.1",
  "description": "Kanban board view for Bases with drag and drop",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "tsc -noEmit -skipLibCheck && eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "obsidian-md",
    "kanban",
    "board",
    "bases",
    "task-management"
  ],
  "author": "Michael DeRazon",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "obsidian": "^1.12.3",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  }
}
