{
  "name": "obsidian-base-board",
  "version": "2.3.1",
  "description": "Kanban board view for Bases with drag and drop",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "tsc -noEmit -skipLibCheck && eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "obsidian-md",
    "kanban",
    "board",
    "bases",
    "task-management"
  ],
  "author": "Michael DeRazon",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@eslint/json": "2.0.0",
    "esbuild": "0.28.1",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-obsidianmd": "0.3.0",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "obsidian": "1.13.1",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0"
  }
}
