{
  "name": "base-board-cli",
  "version": "0.1.1-beta",
  "description": "CLI for Base Board — manage your Obsidian kanban board from the terminal",
  "keywords": [
    "obsidian",
    "kanban",
    "cli",
    "bases",
    "ai-tools"
  ],
  "author": "Michael DeRazon",
  "license": "MIT",
  "type": "module",
  "bin": {
    "bb": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js",
    "dev": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --watch",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  }
}
